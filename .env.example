# Environment Variables — Portfolio
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored and must NEVER be committed to Git.

# ─── Site URL ────────────────────────────────────────────────────────────────
# Set this to your actual Vercel deployment URL after the first deploy.
# Example: https://mahmudul-portfolio.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# ─── Contact Form — Gmail API (OAuth2) ───────────────────────────────────────
#
# HOW TO GET THESE VALUES (one-time setup, ~10 minutes):
#
# STEP 1 — Create a Google Cloud project & enable Gmail API
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project (e.g. "Portfolio Contact")
#   3. Go to "APIs & Services" → "Library"
#   4. Search for "Gmail API" and click Enable
#
# STEP 2 — Create OAuth2 credentials
#   1. Go to "APIs & Services" → "Credentials"
#   2. Click "Create Credentials" → "OAuth Client ID"
#   3. Application type: "Web application"
#   4. Add Authorized redirect URI: https://developers.google.com/oauthplayground
#   5. Click Create — copy the Client ID and Client Secret below
#
# STEP 3 — Get a Refresh Token
#   1. Go to https://developers.google.com/oauthplayground
#   2. Click the gear icon (⚙) top-right → check "Use your own OAuth credentials"
#   3. Paste your Client ID and Client Secret
#   4. In the left panel, find "Gmail API v1" → select:
#        https://mail.google.com/
#   5. Click "Authorize APIs" → sign in with your Gmail account
#   6. Click "Exchange authorization code for tokens"
#   7. Copy the "Refresh token" value below
#
# STEP 4 — Fill in the values below

# Your Google OAuth2 Client ID (from Step 2)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Your Google OAuth2 Client Secret (from Step 2)
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret

# The refresh token you got from OAuth Playground (Step 3)
GMAIL_REFRESH_TOKEN=1//your-refresh-token

# The Gmail address that will SEND the email (must be the account you authorised)
GMAIL_SENDER_EMAIL=mahmudulhasanmaruf78@gmail.com

# The email address that will RECEIVE the contact form submissions
CONTACT_TO_EMAIL=mahmudulhasanmaruf78@gmail.com
