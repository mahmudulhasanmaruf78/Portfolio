# Environment Variables - Portfolio

# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored and should NEVER be committed.

# Site URL
# Set this to your actual deployment URL after the first deploy on Vercel.
# Example: https://mahmudul-portfolio.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Contact Form - SMTP (Nodemailer)
# You need an SMTP mail server to receive contact form submissions.
#
# Recommended free options:
#   - Gmail with an app password: SMTP_HOST=smtp.gmail.com SMTP_PORT=587
#   - Brevo: SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587
#   - Mailgun: SMTP_HOST=smtp.mailgun.org SMTP_PORT=587
#
# For Gmail: enable 2FA, then create an app password from Google Account > Security > App Passwords.
# Use your Gmail address as SMTP_USER and the app password as SMTP_PASS.

CONTACT_TO_EMAIL=mahmudul.hasan@student.aiub.edu
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
